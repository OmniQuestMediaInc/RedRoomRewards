# .gitattributes — RedRoomRewards
# Git merge strategies, line-ending enforcement, and diff quality settings.
#
# Authority: OmniQuest Media Inc.
# Updated: 2026-04-19 (config refresh — legacy copy in LEGACY_CONFIGS/)
#
# TODO: Add binary entries for any new asset types added to the project.

# ── Default: auto-detect text / enforce LF ────────────────────────────────
* text=auto eol=lf

# ── Explicit text formats ─────────────────────────────────────────────────
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.sh        text eol=lf
*.env       text eol=lf

# ── Lock files — accept incoming version on merge ─────────────────────────
# Re-run `npm install` or `yarn install` after merge to reconcile.
package-lock.json   merge=ours
yarn.lock           merge=ours

# ── Binary files — never diff or merge as text ────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary

# ── Diff drivers — improve diff quality for structured files ──────────────
*.ts        diff=typescript
*.tsx       diff=typescript
*.md        diff=markdown
*.json      diff=json
