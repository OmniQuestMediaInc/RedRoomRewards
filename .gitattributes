# .gitattributes — RedRoomRewards
# Merge strategies and file handling for conflict prevention
#
# Authority: OmniQuest Media Inc.
# Date: 2026-04-17

# ──────────────────────────────────────────────
# Lock files — auto-generated; always accept the incoming version
# on merge to avoid unsolvable textual conflicts.
# Re-run `npm install` after merge to reconcile.
# ──────────────────────────────────────────────
package-lock.json merge=ours

# ──────────────────────────────────────────────
# Line endings — enforce LF for all text files
# regardless of contributor OS
# ──────────────────────────────────────────────
* text=auto eol=lf

# Explicitly mark common text formats
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.sh text eol=lf

# Shell scripts need LF and executable bit
# ──────────────────────────────────────────────
# Binary files — never diff or merge as text
# ──────────────────────────────────────────────
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# ──────────────────────────────────────────────
# Diff drivers — improve diff quality for
# structured files
# ──────────────────────────────────────────────
*.ts diff=typescript
*.tsx diff=typescript
*.md diff=markdown
