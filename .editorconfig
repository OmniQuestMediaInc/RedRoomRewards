# .editorconfig — RedRoomRewards
# https://editorconfig.org
#
# Ensures consistent coding styles across different editors and IDEs.
# TODO: Confirm these defaults with your team and adjust as needed.

root = true

# ── All files ─────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# ── TypeScript / JavaScript ────────────────────────────────────────────────
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# ── JSON ──────────────────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ── YAML / GitHub Actions ─────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ── Markdown ──────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# ── Shell scripts ─────────────────────────────────────────────────────────
[*.sh]
indent_size = 2

# ── Makefile ──────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab

# ── Lock files (do not apply formatting) ──────────────────────────────────
[{package-lock.json,yarn.lock,pnpm-lock.yaml}]
indent_size = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
