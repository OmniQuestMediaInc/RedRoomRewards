{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // ── Language & Output ──────────────────────────────────────────────────
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",

    // ── Module Resolution ──────────────────────────────────────────────────
    // TODO: Migrate to "bundler" when moving to Next.js app router
    "moduleResolution": "node",
    // Required for TypeScript 6.x with moduleResolution: "node"
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "esModuleInterop": true,

    // ── Type Checking ─────────────────────────────────────────────────────
    // Relaxed root config — per-service tsconfigs may be stricter independently.
    "strict": false,
    "noImplicitAny": false,
    // TODO: Re-enable these once the codebase reaches full type coverage:
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noImplicitReturns": true,
    // "noFallthroughCasesInSwitch": true,

    // ── Emit ──────────────────────────────────────────────────────────────
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // ── Interop ───────────────────────────────────────────────────────────
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // ── Decorators (NestJS DI requires these) ─────────────────────────────
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // ── Type Roots ────────────────────────────────────────────────────────
    "types": ["node", "jest"]

    // TODO: Add path aliases when the project grows:
    // "paths": {
    //   "@/*": ["./src/*"]
    // }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts", "LEGACY_CONFIGS", "src/api/receipt-endpoint.example.ts"]
}
