# RedRoomRewards Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit .env files with real secrets to git

# ============================================
# Application Environment
# ============================================
NODE_ENV=development  # development | test | production

# ============================================
# Database Configuration
# ============================================
# MongoDB connection string
# Format: mongodb://username:password@host:port/database
# Production: Use MongoDB Atlas or similar with TLS enabled
MONGODB_URI=mongodb://localhost:27017/redroomrewards

# ============================================
# Security & Authentication
# ============================================
# JWT signing secret (REQUIRED, minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-minimum-32-characters-required-here

# Queue authorization token secret (REQUIRED, minimum 32 characters)
# Used for authorizing settlement/refund operations
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QUEUE_AUTH_SECRET=your-secure-queue-auth-secret-minimum-32-characters

# Token expiry in seconds (default: 900 = 15 minutes)
TOKEN_EXPIRY_SECONDS=900

# ============================================
# Webhook Configuration
# ============================================
# RRR webhook signature verification secret (REQUIRED, minimum 32 characters)
# Used to verify incoming webhooks from external systems
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RRR_WEBHOOK_SECRET=your-secure-webhook-secret-minimum-32-characters-required

# ============================================
# Service Configuration
# ============================================
# Service port (default: 3000)
PORT=3000

# API base path
API_BASE_PATH=/api/v1

# ============================================
# Logging & Monitoring
# ============================================
# Log level: debug | info | warn | error
LOG_LEVEL=info

# Enable structured JSON logging
LOG_FORMAT=json

# ============================================
# Feature Flags (Development/Testing)
# ============================================
# Enable debug mode (NEVER in production)
DEBUG_MODE=false

# Enable verbose logging (NEVER in production)
VERBOSE_LOGGING=false

# ============================================
# Rate Limiting
# ============================================
# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=100

# ============================================
# CORS Configuration
# ============================================
# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# GateGuard Sentinel™ — 18+ Age Verification
# ============================================
# Mandatory for every account action (signup, high-value awards, burns).
# Obtain a key from the GateGuard admin console.
GATEGUARD_AV_API_KEY=your-gateguard-key-here
GATEGUARD_AV_ENDPOINT=https://api.gateguard.omniquestmedia.com

# ============================================
# White-Label Service Bureau
# ============================================
# When true, the engine runs in hosted service-bureau mode (multi-tenant).
# When false, the engine runs as a self-hosted single-tenant deployment.
SERVICE_BUREAU_ENABLED=true

# ============================================
# Notes
# ============================================
# 1. All secrets MUST be at least 32 characters long
# 2. Use cryptographically secure random generation for secrets
# 3. Never use default values like 'changeme', 'secret', 'password'
# 4. Rotate secrets quarterly or immediately on compromise
# 5. Store production secrets in secure vault (AWS Secrets Manager, etc.)
# 6. Never commit .env files to git
# 7. See SECURITY_BEST_PRACTICES.md for more information

# ============================================
# Security Checklist
# ============================================
# [ ] All secrets are at least 32 characters
# [ ] Secrets are cryptographically random
# [ ] No default or insecure values used
# [ ] .env file is in .gitignore
# [ ] Production secrets stored in secure vault
# [ ] All required variables are set
