# .markdownlintignore — RedRoomRewards
# Paths markdownlint should skip entirely. These are also excluded by the
# Super-Linter FILTER_REGEX_EXCLUDE in .github/workflows/lint.yml, but listing
# them here means local `npx markdownlint` runs behave the same as CI.

# Application code directories — no markdown enforced here.
src/
api/
infra/

# Build artifacts and dependencies.
node_modules/
dist/
build/
out/
.next/
coverage/
.venv/
vendor/

# Governance archives / legacy / reference libraries (preserved as-authored).
LEGACY_CONFIGS/
archive/
docs/history/
PROGRAM_CONTROL/
REFERENCE_LIBRARY/

# Super-Linter output (generated).
super-linter-output/
