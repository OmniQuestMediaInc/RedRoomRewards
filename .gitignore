# .gitignore — RedRoomRewards
# Next.js 14+ / TypeScript / Node.js / Yarn / VSCode
# Updated: 2026-04-19 (config refresh — legacy copy in LEGACY_CONFIGS/)
# TODO: Review "Custom Exclusions" section for project-specific paths.

# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Build Outputs ─────────────────────────────────────────────────────────
dist/
build/
out/
.next/
*.tsbuildinfo
.tsbuildinfo

# ── Environment Variables ──────────────────────────────────────────────────
# NEVER commit real env files — only the example file is allowed
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
.env.*.local
!.env.example

# ── IDE and Editor Files ───────────────────────────────────────────────────
# VSCode (allow shared workspace settings)
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains (IntelliJ / WebStorm)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ── Operating System Files ─────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
.Trash-*
.nfs*

# ── Testing & Coverage ─────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
junit.xml

# ── Logs ──────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Cache & Runtime ────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.npm/
.eslintcache
.stylelintcache
.node_repl_history
.yarn-integrity
*.tgz

# ── Secrets and Credentials ────────────────────────────────────────────────
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx
.credentials

# ── MongoDB / Database ─────────────────────────────────────────────────────
data/

# ── Temporary Files ────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ── Documentation Build ─────────────────────────────────────────────────────
docs/.vitepress/cache
docs/.vitepress/dist

# ── Miscellaneous ──────────────────────────────────────────────────────────
.serverless/
.webpack/
.dynamodb/
.tern-port
.vscode-test

# ── Archive (read-only governance + history docs — tracked) ──────────────────
# archive/ is intentionally tracked (governance documents, superseded specs).
# Add sub-paths here only for generated/binary artefacts that should not be tracked.

# ── Custom Exclusions ──────────────────────────────────────────────────────
